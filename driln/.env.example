# Driln Configuration
# Copy this file to .env and fill in your values.

# ─── Application ───────────────────────────────────────────────
DRILN_DEBUG=false
DRILN_LOG_LEVEL=INFO

# ─── Database ──────────────────────────────────────────────────
DRILN_DATABASE_URL=sqlite+aiosqlite:///./driln.db

# ─── AI Provider ───────────────────────────────────────────────
DRILN_AI_PROVIDER=openai
DRILN_AI_MODEL=gpt-4o
DRILN_AI_API_KEY=sk-...
# For local models (Ollama, vLLM, etc.):
# DRILN_AI_BASE_URL=http://localhost:11434/v1
DRILN_AI_TEMPERATURE=0.2
DRILN_AI_MAX_TOKENS=4096

# ─── Scanning ─────────────────────────────────────────────────
DRILN_SCAN_TIMEOUT=300
DRILN_SCAN_MAX_CONCURRENT=3
DRILN_SCAN_OUTPUT_DIR=./output

# ─── Tools ─────────────────────────────────────────────────────
DRILN_TOOLS_ENABLED=["nmap","subfinder","httpx","nuclei"]
