<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driln Report — {{ target }}</title>
    <style>
        :root {
            --bg: #0a0a0f;
            --surface: #12121a;
            --border: #1e1e2e;
            --text: #e0e0e8;
            --muted: #8888a0;
            --accent: #7c5cff;
            --critical: #ff3b5c;
            --high: #ff6b35;
            --medium: #ffb800;
            --low: #00c8ff;
            --info: #6b7280;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            padding: 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }
        h1 { color: var(--accent); font-size: 1.8rem; margin-bottom: 0.5rem; }
        h2 { color: var(--text); font-size: 1.3rem; margin: 2rem 0 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
        h3 { color: var(--muted); font-size: 1.1rem; margin: 1.5rem 0 0.5rem; }
        .meta { color: var(--muted); font-size: 0.85rem; margin-bottom: 2rem; }
        .meta span { display: inline-block; margin-right: 1.5rem; }
        table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
        th, td { padding: 0.6rem 0.8rem; text-align: left; border-bottom: 1px solid var(--border); }
        th { color: var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; }
        .badge {
            display: inline-block;
            padding: 0.15rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
        }
        .badge-critical { background: var(--critical); color: #fff; }
        .badge-high { background: var(--high); color: #fff; }
        .badge-medium { background: var(--medium); color: #000; }
        .badge-low { background: var(--low); color: #000; }
        .badge-info { background: var(--info); color: #fff; }
        .finding {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1rem 1.2rem;
            margin: 0.8rem 0;
        }
        .finding-title { font-weight: 600; margin-bottom: 0.4rem; }
        .finding-meta { color: var(--muted); font-size: 0.85rem; }
        .finding-desc { margin-top: 0.6rem; font-size: 0.9rem; white-space: pre-wrap; }
        .ai-analysis {
            background: linear-gradient(135deg, rgba(124,92,255,0.08), rgba(124,92,255,0.02));
            border: 1px solid rgba(124,92,255,0.2);
            border-radius: 8px;
            padding: 1.2rem;
            margin: 1rem 0;
            white-space: pre-wrap;
        }
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 0.8rem;
            margin: 1rem 0;
        }
        .summary-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1rem;
            text-align: center;
        }
        .summary-card .count { font-size: 1.8rem; font-weight: 700; }
        .summary-card .label { font-size: 0.75rem; color: var(--muted); text-transform: uppercase; }
        footer { margin-top: 3rem; color: var(--muted); font-size: 0.8rem; text-align: center; }
    </style>
</head>
<body>
    <h1>Driln Security Report</h1>
    <div class="meta">
        <span><strong>Target:</strong> {{ target }}</span>
        <span><strong>Type:</strong> {{ scan_type }}</span>
        <span><strong>Status:</strong> {{ status }}</span>
        <span><strong>Scan ID:</strong> {{ scan_id[:8] }}…</span>
    </div>

    <h2>Executive Summary</h2>
    <div class="summary-grid">
        <div class="summary-card">
            <div class="count">{{ total_findings }}</div>
            <div class="label">Total Findings</div>
        </div>
        {% for sev, color in [("critical", "critical"), ("high", "high"), ("medium", "medium"), ("low", "low"), ("info", "info")] %}
        {% if severity_counts.get(sev, 0) > 0 %}
        <div class="summary-card">
            <div class="count" style="color: var(--{{ color }});">{{ severity_counts[sev] }}</div>
            <div class="label">{{ sev | upper }}</div>
        </div>
        {% endif %}
        {% endfor %}
    </div>

    {% if ai_summary %}
    <h2>AI Analysis</h2>
    <div class="ai-analysis">{{ ai_summary }}</div>
    {% endif %}

    <h2>Tool Execution</h2>
    <table>
        <thead>
            <tr><th>Tool</th><th>Status</th><th>Exit Code</th><th>Duration</th><th>Findings</th></tr>
        </thead>
        <tbody>
        {% for tr in tool_runs %}
            <tr>
                <td><strong>{{ tr.tool_name }}</strong></td>
                <td>{{ tr.status }}</td>
                <td>{{ tr.exit_code if tr.exit_code is not none else "—" }}</td>
                <td>{{ "%.1f" | format(tr.duration_seconds) if tr.duration_seconds else "—" }}s</td>
                <td>{{ tr.finding_count }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <h2>Findings</h2>
    {% for sev in ["critical", "high", "medium", "low", "info"] %}
    {% set sev_findings = findings | selectattr("severity", "equalto", sev) | list %}
    {% if sev_findings %}
    <h3><span class="badge badge-{{ sev }}">{{ sev }}</span> ({{ sev_findings | length }})</h3>
    {% for f in sev_findings %}
    <div class="finding">
        <div class="finding-title">{{ f.title }}</div>
        <div class="finding-meta">
            {% if f.host %}Host: {{ f.host }}{% if f.port %}:{{ f.port }}{% endif %} · {% endif %}
            {% if f.service %}Service: {{ f.service }} · {% endif %}
            {% if f.protocol %}Protocol: {{ f.protocol }}{% endif %}
        </div>
        {% if f.description %}
        <div class="finding-desc">{{ f.description }}</div>
        {% endif %}
    </div>
    {% endfor %}
    {% endif %}
    {% endfor %}

    <footer>
        Report generated by Driln · {{ generated_at }}
    </footer>
</body>
</html>
